# Required: GitHub token with repo content write access
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: target repository defaults
REPO_OWNER=aminssutt
REPO_NAME=Fabulous
REPO_BRANCH=gh-pages

# Optional: protect /publish with a shared secret header x-publish-secret
OPTIONAL_BASIC_SECRET=change_me

# Optional: service port
PORT=3000
